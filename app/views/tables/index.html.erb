<%= turbo_stream_from "store_#{Current.store.id}_tables" %>

<div class="section-header">
  <h1 class="section-title"><%= t("tables.title") %></h1>
</div>

<div class="tables-grid">
  <% @tables.each do |table| %>
    <% order = @active_orders[table.id] %>
    <%= render "tables/table", table: table, order: order %>
  <% end %>
</div>

<div class="legend mt-2">
  <div class="legend-item">
    <span class="legend-dot" style="background: var(--color-border)"></span>
    <%= t("tables.available") %>
  </div>
  <div class="legend-item">
    <span class="legend-dot" style="background: var(--color-warning)"></span>
    <%= t("order_statuses.cooking") %>
  </div>
  <div class="legend-item">
    <span class="legend-dot" style="background: var(--color-success)"></span>
    <%= t("order_statuses.ready") %>
  </div>
  <div class="legend-item">
    <span class="legend-dot" style="background: var(--color-purple)"></span>
    <%= t("order_statuses.delivered") %>
  </div>
</div>
