<%= turbo_refreshes_with method: :morph, scroll: :preserve %>
<%= turbo_stream_from "store_#{Current.store.id}_tables" %>

<% content_for :title, t("tables.title") %>

<div class="grid grid-cols-[repeat(auto-fill,minmax(140px,1fr))] gap-3">
  <% @spots.each do |spot| %>
    <% order = @active_orders[spot.id] %>
    <%= render "tables/table", spot: spot, order: order %>
  <% end %>
</div>

<div class="flex flex-wrap gap-4 py-3 text-sm text-muted-foreground mt-2">
  <div class="flex items-center gap-1.5">
    <span class="size-3 rounded-full bg-border"></span>
    <%= t("tables.available") %>
  </div>
  <div class="flex items-center gap-1.5">
    <span class="size-3 rounded-full bg-[oklch(0.7_0.15_55)]"></span>
    <%= t("order_statuses.cooking") %>
  </div>
  <div class="flex items-center gap-1.5">
    <span class="size-3 rounded-full bg-[oklch(0.6_0.2_145)]"></span>
    <%= t("order_statuses.ready") %>
  </div>
  <div class="flex items-center gap-1.5">
    <span class="size-3 rounded-full bg-[oklch(0.6_0.2_300)]"></span>
    <%= t("order_statuses.delivered") %>
  </div>
</div>
