<%= turbo_stream_from "store_#{Current.store.id}_takeouts" %>

<div class="section-header">
  <h1 class="section-title"><%= t("takeouts.title") %></h1>
  <%= link_to spot_orders_path(@spot), class: "btn btn-primary", data: { turbo_method: :post } do %>
    <%= t("takeouts.new_order") %>
  <% end %>
</div>

<% if @orders.any? %>
  <div class="takeout-orders" id="takeout-orders">
    <% @orders.each do |order| %>
      <%= render "takeouts/order_card", order: order %>
    <% end %>
  </div>
<% else %>
  <p class="text-muted mt-2"><%= t("takeouts.no_orders") %></p>
<% end %>
