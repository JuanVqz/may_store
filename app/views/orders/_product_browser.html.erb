<%= turbo_frame_tag "product_browser" do %>
  <div class="flex gap-2 overflow-x-auto pb-2 mt-2 mb-4">
    <% categories.each do |cat| %>
      <%= link_to cat.name,
            order_path(order, category_id: cat.id),
            data: { turbo_frame: "product_browser" },
            class: "shrink-0 px-4 py-2 rounded-lg border text-sm font-medium no-underline transition #{cat == category ? 'bg-primary text-primary-foreground border-primary' : 'bg-card text-foreground border-border hover:border-primary hover:text-primary'}" %>
    <% end %>
  </div>

  <% if products.any? %>
    <%= render "components/card" do %>
      <% products.each do |product| %>
        <div class="flex flex-wrap md:flex-nowrap gap-2 md:gap-4 p-4 border-b border-border last:border-b-0">
          <div class="size-16 rounded-lg bg-muted shrink-0 flex items-center justify-center text-2xl">&#9749;</div>
          <div class="flex-1 min-w-0">
            <div class="font-semibold text-sm"><%= product.name %></div>
            <div class="text-sm text-muted-foreground mt-0.5"><%= product.description %></div>
          </div>
          <div class="flex w-full md:w-auto md:flex-col items-center md:items-end justify-between gap-1">
            <span class="font-bold text-primary"><%= product.formatted_base_price %></span>
            <div class="flex gap-1">
              <%= button_to t("products.add_to_order"),
                    order_line_items_path(order, line_item: { product_id: product.id }),
                    method: :post,
                    data: { component: "button", variant: "primary", size: "sm" } %>
              <% if product.allows_customization && product.product_components.any? %>
                <button type="button"
                        data-action="click->order-page#toggleCustomization"
                        data-product-id="<%= product.id %>"
                        data-url="<%= new_order_line_item_path(order, product_id: product.id) %>"
                        data-component="button" data-variant="outline" data-size="sm">
                  <%= t("products.customize") %>
                </button>
              <% end %>
            </div>
          </div>
        </div>
        <div id="customization_product_<%= product.id %>"></div>
      <% end %>
    <% end %>
  <% else %>
    <p class="text-center text-muted-foreground mt-4"><%= t("no_results") %></p>
  <% end %>
<% end %>
