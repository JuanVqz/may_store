<div class="max-w-md mx-auto p-8 text-center space-y-6 mt-12">
  <h1 class="text-2xl font-bold"><%= t("order.closed_title") %></h1>

  <dl class="space-y-2 text-sm">
    <div>
      <dt class="text-muted-foreground inline"><%= t("bill.order") %>:</dt>
      <dd class="inline font-medium"><%= order.code %></dd>
    </div>
    <div>
      <dt class="text-muted-foreground inline"><%= t("bill.total") %>:</dt>
      <dd class="inline font-medium"><%= order.formatted_total %></dd>
    </div>
    <p class="text-muted-foreground"><%= t("order.table_now_available", name: order.spot.name) %></p>
  </dl>

  <%= link_to t("order.back_to_tables"), tables_path,
        class: "inline-block",
        data: { component: "button", variant: "primary", size: "lg" } %>
</div>
