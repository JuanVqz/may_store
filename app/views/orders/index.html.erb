<% content_for :title, t("orders_today.title") %>

<div class="space-y-3">
  <% @orders.each do |order| %>
    <%= link_to order_path(order), class: "block" do %>
      <%= render "components/card" do %>
        <%= render "components/card/content" do %>
          <div class="flex items-center justify-between">
            <div class="flex-1">
              <div class="flex items-center gap-2">
                <span class="font-medium"><%= order.spot.name %></span>
                <span class="text-muted-foreground"><%= order.code %></span>
              </div>
              <div class="text-sm text-muted-foreground mt-1">
                <%= l(order.created_at, format: :short) %> &middot; <%= order.user.name %>
              </div>
              <% counts = order.readiness_counts %>
              <% if order.closed? && counts[:delivered] < counts[:total] %>
                <div class="text-sm text-orange-500 font-medium">
                  <%= t("orders_today.partial_delivery", delivered: counts[:delivered], total: counts[:total]) %>
                </div>
              <% elsif counts[:total] > 0 %>
                <div class="text-sm text-muted-foreground">
                  <%= t("orders_today.items_count", count: counts[:total]) %>
                </div>
              <% end %>
            </div>
            <div class="text-right">
              <span class="<%= status_badge_classes(order.status) %>"><%= order.status_label %></span>
              <div class="font-bold text-primary mt-1"><%= order.formatted_total %></div>
            </div>
          </div>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <% if @orders.none? %>
    <div class="text-center text-muted-foreground py-8">
      <%= t("orders_today.no_orders") %>
    </div>
  <% end %>
</div>
