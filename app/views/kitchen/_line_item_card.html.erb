<%
  wait_minutes = ((Time.current - item.created_at) / 60).floor
  is_oldest = local_assigns[:oldest_cooking_id] == item.id && item.cooking?
  spot = item.order.spot
  spot_label = spot.takeout? ? t("spot_types.takeout").upcase : spot.name.upcase
%>

<div id="kitchen_line_item_<%= item.id %>" class="kitchen-card <%= 'kitchen-card--oldest' if is_oldest %> <%= 'kitchen-card--ready' if item.ready? %>">
  <div class="kitchen-card-header">
    <% if is_oldest %>
      <div class="kitchen-card-banner kitchen-card-banner--oldest">
        <%= t("kitchen.oldest").upcase %> - <%= t("kitchen.waiting", minutes: wait_minutes) %>
      </div>
    <% elsif item.ready? %>
      <div class="kitchen-card-banner kitchen-card-banner--ready">
        <%= t("kitchen.waiting_for_waiter") %>
      </div>
    <% else %>
      <div class="kitchen-card-banner">
        <%= t("kitchen.waiting", minutes: wait_minutes) %>
      </div>
    <% end %>
    <div class="kitchen-card-meta">
      <strong><%= spot_label %></strong> |
      <%= item.order.code %> |
      <%= l(item.order.opened_at || item.order.created_at, format: :time_only) %> |
      <%= item.order.user.name %>
    </div>
  </div>

  <div class="kitchen-card-body">
    <div class="kitchen-card-product"><%= item.product.name.upcase %></div>

    <% ingredients = item.line_item_components.select(&:ingredient?) %>
    <% extras = item.line_item_components.select(&:extra?) %>

    <% if ingredients.any? %>
      <% modified = ingredients.select { |c| c.portion.to_f != 1.0 } %>
      <div class="kitchen-card-details">
        <% if modified.any? %>

          <% modified.each do |c| %>
            <div><%= c.component.name %>: <%= c.portion_label %> *</div>
          <% end %>

        <% else %>
          <%= t("line_item.standard_preparation") %>
        <% end %>
      </div>
    <% end %>

    <% if extras.any? %>
      <div class="kitchen-card-details">
        <% extras.group_by(&:component_id).each do |_, group| %>
          <div>+ <%= group.first.component.name %> x<%= group.size %></div>
        <% end %>
      </div>
    <% end %>

    <% if item.special_notes.present? %>
      <div class="kitchen-card-notes"><em><%= item.special_notes %></em></div>
    <% end %>
  </div>

  <div class="kitchen-card-actions">
    <% if item.cooking? %>
      <%= button_to t("kitchen.ready"),
            ready_order_line_item_path(item.order, item),
            method: :patch,
            class: "btn btn-primary" %>
      <%= button_to t("kitchen.cancel"),
            cancel_order_line_item_path(item.order, item),
            method: :patch,
            class: "btn btn-danger",
            data: { turbo_confirm: t("kitchen.cancel_confirm") } %>
    <% elsif item.ready? %>
      <%= button_to t("line_item.mark_delivered"),
            deliver_order_line_item_path(item.order, item),
            method: :patch,
            class: "btn btn-primary" %>
      <%= button_to t("kitchen.cancel"),
            cancel_order_line_item_path(item.order, item),
            method: :patch,
            class: "btn btn-danger",
            data: { turbo_confirm: t("kitchen.cancel_confirm") } %>
    <% end %>
  </div>
</div>
