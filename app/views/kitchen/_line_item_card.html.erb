<%
  wait_minutes = ((Time.current - item.created_at) / 60).floor
  is_oldest = local_assigns[:oldest_cooking_id] == item.id && item.cooking?
  spot = item.order.spot
  spot_label = spot.takeout? ? t("spot_types.takeout").upcase : spot.name.upcase
  border_class = if is_oldest
    "border-l-4 border-l-destructive"
  elsif item.ready?
    "border-l-4 border-l-green-500"
  else
    ""
  end
%>

<%= render "components/card", css_classes: "overflow-hidden #{border_class}" do %>
  <div class="px-4 pt-3">
    <% if is_oldest %>
      <div class="text-sm font-semibold text-destructive-foreground mb-1">
        <%= t("kitchen.oldest").upcase %> - <%= t("kitchen.waiting", minutes: wait_minutes) %>
      </div>
    <% elsif item.ready? %>
      <div class="text-sm font-semibold text-green-700 mb-1">
        <%= t("kitchen.waiting_for_waiter") %>
      </div>
    <% else %>
      <div class="text-sm font-semibold text-muted-foreground mb-1">
        <%= t("kitchen.waiting", minutes: wait_minutes) %>
      </div>
    <% end %>
    <div class="text-sm text-muted-foreground">
      <strong><%= spot_label %></strong> |
      <%= item.order.code %> |
      <%= l(item.order.opened_at || item.order.created_at, format: :time_only) %> |
      <%= item.order.user.name %>
    </div>
  </div>

  <%= render "components/card/content" do %>
    <div class="font-bold text-lg mb-1 kitchen-product-name"><%= item.product.name.upcase %></div>

    <% ingredients = item.line_item_components.select(&:ingredient?) %>
    <% extras = item.line_item_components.select(&:extra?) %>

    <% if ingredients.any? %>
      <% modified = ingredients.select { |c| c.portion.to_f != 1.0 } %>
      <div class="text-sm text-muted-foreground">
        <% if modified.any? %>
          <% modified.each do |c| %>
            <div><%= c.component.name %>: <%= c.portion_label %> *</div>
          <% end %>
        <% else %>
          <%= t("line_item.standard_preparation") %>
        <% end %>
      </div>
    <% end %>

    <% if extras.any? %>
      <div class="text-sm text-muted-foreground">
        <% extras.group_by(&:component_id).each do |_, group| %>
          <div>+ <%= group.first.component.name %> x<%= group.size %></div>
        <% end %>
      </div>
    <% end %>

    <% if item.special_notes.present? %>
      <div class="text-sm text-orange-600 mt-1"><em><%= item.special_notes %></em></div>
    <% end %>
  <% end %>

  <%= render "components/card/footer" do %>
    <div class="flex gap-2 w-full">
      <% if item.cooking? %>
        <%= button_to t("kitchen.ready"),
              ready_order_line_item_path(item.order, item),
              method: :patch,
              class: "flex-1",
              data: { component: "button", variant: "primary", size: "lg" } %>
        <%= button_to t("kitchen.cancel"),
              cancel_order_line_item_path(item.order, item),
              method: :patch,
              class: "flex-1",
              data: { component: "button", variant: "destructive", size: "lg", turbo_confirm: t("kitchen.cancel_confirm") } %>
      <% elsif item.ready? %>
        <%= button_to t("line_item.mark_delivered"),
              deliver_order_line_item_path(item.order, item),
              method: :patch,
              class: "flex-1",
              data: { component: "button", variant: "primary", size: "lg" } %>
        <%= button_to t("kitchen.cancel"),
              cancel_order_line_item_path(item.order, item),
              method: :patch,
              class: "flex-1",
              data: { component: "button", variant: "destructive", size: "lg", turbo_confirm: t("kitchen.cancel_confirm") } %>
      <% end %>
    </div>
  <% end %>
<% end %>
