<%# locals: (spot:) %>
<div class="flex items-center justify-end gap-2">
  <%= link_to t("edit"), edit_admin_spot_path(spot),
    data: { component: "button", variant: "ghost", size: "sm" } %>
  <%= button_to t("delete"), admin_spot_path(spot), method: :delete,
    data: { component: "button", variant: "ghost", size: "sm",
            turbo_confirm: t("admin.confirm_delete") } %>
</div>
