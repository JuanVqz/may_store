<% content_for :title, t("admin.spots.title") %>

<%= render "admin/shared/nav" %>

<%= render "components/card" do %>
  <%= render "components/card/header", layout: :row do %>
    <div>
      <%= render "components/card/title", text: t("admin.spots.title") %>
    </div>
    <%= render "components/card/action" do %>
      <%= link_to t("admin.spots.new"), new_admin_spot_path,
        data: { component: "button", variant: "default", size: "sm" } %>
    <% end %>
  <% end %>
  <%= render "components/card/content" do %>
    <%= render "admin/shared/search", url: admin_spots_path,
      placeholder: t("admin.spots.search_placeholder") %>
  <% end %>
  <%= render "components/card/content", spacing: :full do %>
    <%= render "components/simple_table",
      collection: @spots,
      empty_message: t("no_results"),
      columns: [
        { key: :name, label: t("admin.spots.attributes.name") },
        { key: ->(s) { t("spot_types.#{s.spot_type}") }, label: t("admin.spots.attributes.spot_type") },
        { key: ->(s) { render "admin/spots/active_badge", spot: s }, label: t("admin.spots.attributes.active") },
        { key: ->(s) { render "admin/spots/actions", spot: s }, label: "" }
      ] %>
  <% end %>
  <%= render "components/card/content" do %>
    <%= render "admin/shared/pagination", pagy: @pagy %>
  <% end %>
<% end %>
