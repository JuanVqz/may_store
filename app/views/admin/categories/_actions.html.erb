<%# locals: (category:) %>
<div class="flex items-center justify-end gap-2">
  <%= link_to t("edit"), edit_admin_category_path(category),
    data: { component: "button", variant: "ghost", size: "sm" } %>
  <%= button_to t("delete"), admin_category_path(category), method: :delete,
    data: { component: "button", variant: "ghost", size: "sm",
            turbo_confirm: t("admin.confirm_delete") } %>
</div>
