<%# locals: (component:) %>
<%= form_with model: [:admin, component], class: "space-y-4" do |f| %>
  <% if component.errors.any? %>
    <%= render "components/alert", variant: :destructive do %>
      <ul class="list-disc list-inside text-sm">
        <% component.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    <% end %>
  <% end %>

  <div>
    <%= f.label :name, t("admin.components.attributes.name"), class: "block text-sm font-medium mb-1" %>
    <%= f.text_field :name, class: "w-full", data: { component: "input" } %>
  </div>

  <div>
    <%= f.label :price, t("admin.components.attributes.price"), class: "block text-sm font-medium mb-1" %>
    <%= f.number_field :price, step: 0.01, min: 0, class: "w-full", data: { component: "input" } %>
  </div>

  <div class="flex items-center gap-2">
    <%= f.check_box :available, data: { component: "checkbox" } %>
    <%= f.label :available, t("admin.components.attributes.available"), class: "text-sm font-medium" %>
  </div>

  <div class="flex gap-2">
    <%= f.submit t("save"), data: { component: "button", variant: "default" } %>
    <%= link_to t("cancel"), admin_components_path,
      data: { component: "button", variant: "outline" } %>
  </div>
<% end %>
