<%# locals: (payment_method:) %>
<div class="flex items-center justify-end gap-2">
  <%= link_to t("edit"), edit_admin_payment_method_path(payment_method),
    data: { component: "button", variant: "ghost", size: "sm" } %>
  <%= button_to t("delete"), admin_payment_method_path(payment_method), method: :delete,
    data: { component: "button", variant: "ghost", size: "sm",
            turbo_confirm: t("admin.confirm_delete") } %>
</div>
