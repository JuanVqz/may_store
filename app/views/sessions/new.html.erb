<% content_for(:title) { t("login.title") } %>

<div class="login-container">
  <div class="card login-card">
    <div class="login-header">
      <h1><%= t("app_name") %></h1>
      <p><%= t("login.title") %></p>
    </div>

    <div class="card-body">
      <% if flash[:alert] %>
        <div class="flash flash-alert mb-2"><%= flash[:alert] %></div>
      <% end %>
      <% if flash[:notice] %>
        <div class="flash flash-notice mb-2"><%= flash[:notice] %></div>
      <% end %>

      <%= form_with url: login_path, method: :post do |f| %>
        <div class="form-group">
          <%= f.label :employee_number, t("login.employee_number"), class: "form-label" %>
          <%= f.text_field :employee_number, class: "form-input", autofocus: true, autocomplete: "username" %>
        </div>

        <div class="form-group">
          <%= f.label :password, t("login.password"), class: "form-label" %>
          <%= f.password_field :password, class: "form-input", autocomplete: "current-password" %>
        </div>

        <%= f.submit t("login.submit"), class: "btn btn-primary btn-block btn-lg" %>
      <% end %>
    </div>
  </div>
</div>
