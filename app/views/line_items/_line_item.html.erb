<div id="line_item_<%= item.id %>" class="product-card">
  <div class="product-info">
    <div class="product-name">
      <%= item.product.name %>
      <span class="status-badge" style="background: <%= item.status_color %>"><%= item.status_label %></span>
    </div>
    <% ingredients = item.line_item_components.select(&:ingredient?) %>
    <% extras = item.line_item_components.select(&:extra?) %>
    <% if ingredients.any? %>
      <div class="product-desc">
        <%= ingredients.map { |c| "#{c.component.name}: #{c.portion_label}" }.join(", ") %>
      </div>
    <% end %>
    <% if extras.any? %>
      <div class="product-desc">
        <% extras.group_by(&:component_id).each do |_, group| %>
          + <%= group.first.component.name %> x<%= group.size %>
        <% end %>
      </div>
    <% end %>
    <% if item.special_notes.present? %>
      <div class="product-desc"><em><%= item.special_notes %></em></div>
    <% end %>
    <div class="product-footer">
      <span class="product-price"><%= item.formatted_total_price %></span>
      <% if item.ordering? %>
        <%= button_to t("delete"),
              order_line_item_path(order, item),
              method: :delete,
              class: "btn btn-sm btn-danger" %>
      <% end %>
      <% if item.cooking? %>
        <%= button_to t("kitchen.ready"),
              ready_order_line_item_path(order, item),
              method: :patch,
              class: "btn btn-sm btn-primary" %>
      <% end %>
      <% if item.ready? %>
        <%= button_to t("line_item.mark_delivered"),
              deliver_order_line_item_path(order, item),
              method: :patch,
              class: "btn btn-sm btn-primary" %>
      <% end %>
    </div>
  </div>
</div>
