<nav class="navbar navbar-back">
  <div>
    <%= link_to "← #{t('products.browse')}", order_products_path(@order) %>
  </div>
  <div>
    <strong><%= @order.code %></strong>
  </div>
</nav>

<div class="card mt-2">
  <div class="card-body text-center">
    <h2><%= @product.name %></h2>
    <p class="text-muted"><%= @product.description %></p>
    <p class="product-price"><%= @product.formatted_base_price %></p>
  </div>
</div>

<%= form_with url: order_line_items_path(@order), method: :post do |f| %>
  <%= f.hidden_field "line_item[product_id]", value: @product.id %>

  <% if @ingredients.any? %>
    <div class="section-header mt-2">
      <h3 class="section-title"><%= t("customization.ingredients") %></h3>
    </div>

    <div class="card">
      <% @ingredients.each do |pc| %>
        <div class="product-card" style="flex-direction: column; align-items: stretch;">
          <div style="display: flex; justify-content: space-between; align-items: center;">
            <strong><%= pc.component.name %></strong>
            <span class="text-muted">$0.00</span>
          </div>
          <div style="display: flex; gap: 0.375rem; margin-top: 0.5rem; flex-wrap: wrap;">
            <% unless pc.required? %>
              <label class="btn btn-sm btn-outline">
                <input type="radio" name="ingredients[<%= pc.component_id %>]" value="0.0" style="display:none">
                <%= t("portions.none") %>
              </label>
            <% end %>
            <% [[0.25, "portions.quarter"], [0.5, "portions.half"], [0.75, "portions.three_quarters"], [1.0, "portions.full"]].each do |val, key| %>
              <label class="btn btn-sm <%= val == 1.0 ? 'btn-primary' : 'btn-outline' %>">
                <input type="radio" name="ingredients[<%= pc.component_id %>]" value="<%= val %>" <%= 'checked' if val == 1.0 %> style="display:none">
                <%= t(key) %>
              </label>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if @extras.any? %>
    <div class="section-header mt-2">
      <h3 class="section-title"><%= t("customization.extras") %></h3>
    </div>

    <div class="card">
      <% @extras.each do |pc| %>
        <div class="product-card" style="display: flex; justify-content: space-between; align-items: center;">
          <div>
            <strong><%= pc.component.name %></strong>
            <span class="text-muted"><%= pc.component.formatted_price %></span>
          </div>
          <div style="display: flex; align-items: center; gap: 0.5rem;">
            <input type="number" name="extras[<%= pc.component_id %>]" value="0" min="0" max="10"
                   class="form-input" style="width: 60px; text-align: center; padding: 0.375rem;">
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="form-group mt-2">
    <label class="form-label"><%= t("line_item.special_notes") %></label>
    <textarea name="special_notes" class="form-input" rows="2" placeholder="<%= t('line_item.special_notes') %>"></textarea>
  </div>

  <div class="mt-2">
    <%= f.submit t("products.add_to_order"), class: "btn btn-primary btn-block btn-lg" %>
  </div>
<% end %>
