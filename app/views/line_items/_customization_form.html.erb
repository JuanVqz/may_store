<div class="customization-inline" data-controller="customization" data-customization-base-price-value="<%= product.base_price_cents %>">
  <span class="hidden" data-customization-target="totalPrice"></span>

  <%= form_with url: order_line_items_path(order), method: :post, data: { turbo_stream: true } do |f| %>
    <%= f.hidden_field "line_item[product_id]", value: product.id %>

    <% if ingredients.any? %>
      <div class="customization-section mb-1">
        <h3><%= t("customization.ingredients") %></h3>

        <% ingredients.each do |pc| %>
          <div class="customization-ingredient">
            <div><strong class="customization-ingredient-name"><%= pc.component.name %></strong></div>
            <div class="portion-group" data-portion-group>
              <% unless pc.required? %>
                <label class="btn btn-sm btn-outline" data-action="click->customization#selectPortion">
                  <input type="radio" name="ingredients[<%= pc.component_id %>]" value="0.0">
                  <%= t("portions.none") %>
                </label>
              <% end %>
              <% [[0.25, "portions.quarter"], [0.5, "portions.half"], [0.75, "portions.three_quarters"], [1.0, "portions.full"]].each do |val, key| %>
                <label class="btn btn-sm <%= val == 1.0 ? 'btn-primary' : 'btn-outline' %>" data-action="click->customization#selectPortion">
                  <input type="radio" name="ingredients[<%= pc.component_id %>]" value="<%= val %>" <%= 'checked' if val == 1.0 %>>
                  <%= t(key) %>
                </label>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <% if extras.any? %>
      <div class="customization-section mb-1">
        <h3><%= t("customization.extras") %></h3>

        <% extras.each do |pc| %>
          <div class="extra-row" data-extra-row>
            <div>
              <strong class="extra-row-name"><%= pc.component.name %></strong>
              <span class="text-muted extra-row-price"><%= pc.component.formatted_price %></span>
            </div>
            <div class="extra-row-controls">
              <button type="button" class="btn btn-sm btn-outline" data-action="click->customization#decrement">-</button>
              <input type="number" name="extras[<%= pc.component_id %>]" value="0" min="0" max="10"
                     class="form-input extra-qty-input"
                     data-customization-target="extraQuantity"
                     data-unit-price="<%= pc.component.price_cents %>"
                     data-action="change->customization#recalculate">
              <button type="button" class="btn btn-sm btn-outline" data-action="click->customization#increment">+</button>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <div class="form-group mt-1">
      <textarea name="special_notes" class="form-input customization-notes" rows="1" placeholder="<%= t('line_item.special_notes') %>"></textarea>
    </div>

    <div class="customization-actions">
      <%= f.submit t("products.add_to_order"), class: "btn btn-success btn-submit" %>
      <button type="button" class="btn btn-gray" data-action="click->order-page#closeCustomization"><%= t("cancel") %></button>
    </div>
  <% end %>
</div>
